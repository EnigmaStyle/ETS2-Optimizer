<Window x:Class="Ets2Optimizer.RestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ripristina backup" Height="420" Width="520"
        Background="#10162B"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#EDF0F5" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9AA5C0" />
        <SolidColorBrush x:Key="AccentBlue" Color="#2E86D9" />
        <SolidColorBrush x:Key="CardBackground" Color="#171F3B" />
        <SolidColorBrush x:Key="BorderColor" Color="#2A3560" />

        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="{StaticResource AccentBlue}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2A3560" />
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Ripristina backup" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8" />
        <TextBlock Grid.Row="1" Text="Scegli un backup da ripristinare. Lo stato attuale del config.cfg verrà a sua volta salvato prima di sovrascrivere, quindi anche questa operazione è reversibile." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,14" />

        <ListBox x:Name="BackupsList" Grid.Row="2" Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Annulla" Style="{StaticResource PrimaryButton}" Background="#2A3560" Click="CancelButton_Click" Margin="0,0,10,0" />
            <Button x:Name="RestoreButton" Content="Ripristina" Style="{StaticResource PrimaryButton}" Click="RestoreButton_Click" IsEnabled="False" />
        </StackPanel>
    </Grid>
</Window>

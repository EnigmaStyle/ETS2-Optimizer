<Window x:Class="Ets2Optimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ets2Optimizer"
        mc:Ignorable="d"
        Title="ETS2 Optimizer" Height="780" Width="760"
        Background="#10162B"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#171F3B" />
        <SolidColorBrush x:Key="BorderColor" Color="#2A3560" />
        <SolidColorBrush x:Key="TextPrimary" Color="#EDF0F5" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9AA5C0" />
        <SolidColorBrush x:Key="AccentBlue" Color="#2E86D9" />
        <SolidColorBrush x:Key="AccentGreen" Color="#2ECC71" />
        <SolidColorBrush x:Key="AccentRed" Color="#E74C3C" />
        <SolidColorBrush x:Key="AccentYellow" Color="#F1C40F" />

        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="{StaticResource AccentBlue}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2A3560" />
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Image Source="Assets/icon.ico" Width="40" Height="40" Margin="0,0,12,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ETS2 Optimizer" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="Ottimizzazione automatica del config.cfg in base al tuo hardware" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" x:Name="HelpButton" Content="? Come si usa" Style="{StaticResource PrimaryButton}" Click="HelpButton_Click" VerticalAlignment="Center" />
        </Grid>

        <!-- Game running warning -->
        <Border Grid.Row="1" x:Name="GameRunningWarning" Background="#3A2A0E" BorderBrush="{StaticResource AccentYellow}" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,14" Visibility="Collapsed">
            <TextBlock Text="Il gioco è aperto: ETS2 sovrascrive config.cfg quando lo chiudi, quindi qualsiasi modifica applicata ora andrebbe persa. Chiudi il gioco prima di applicare le ottimizzazioni." Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
        </Border>

        <!-- Hardware card -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="HARDWARE RILEVATO" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8" />
                    <TextBlock x:Name="GpuText" Text="GPU: —" Foreground="{StaticResource TextPrimary}" Margin="0,2" />
                    <TextBlock x:Name="CpuText" Text="CPU: —" Foreground="{StaticResource TextPrimary}" Margin="0,2" />
                    <TextBlock x:Name="RamText" Text="RAM: —" Foreground="{StaticResource TextPrimary}" Margin="0,2" />
                </StackPanel>
                <Border Grid.Column="1" x:Name="TierBadge" Background="{StaticResource AccentBlue}" CornerRadius="14" Padding="14,6" VerticalAlignment="Top">
                    <TextBlock x:Name="TierText" Text="—" Foreground="White" FontWeight="Bold" />
                </Border>
            </Grid>
        </Border>

        <!-- Config file card -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="FILE DI CONFIGURAZIONE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8" />
                <TextBlock x:Name="ConfigPathText" Text="Nessun file trovato" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Launch options card -->
        <Border Grid.Row="4" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="COMANDI DI AVVIO STEAM CONSIGLIATI" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8" />
                <TextBlock Text="Incollali tu stesso in Steam: tasto destro su ETS2 → Proprietà → Opzioni di avvio. Il tool non modifica Steam." FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8" TextWrapping="Wrap" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="LaunchOptionsText" Grid.Column="0" IsReadOnly="True" Background="#0F1530" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource BorderColor}" Padding="8" VerticalContentAlignment="Center" FontFamily="Consolas" />
                    <Button Grid.Column="1" Content="Copia" Style="{StaticResource PrimaryButton}" Click="CopyLaunchOptions_Click" Margin="10,0,0,0" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Changes list -->
        <Border Grid.Row="5" Style="{StaticResource Card}" Margin="0,0,0,14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="MODIFICHE PROPOSTE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8" />
                <ListView x:Name="ChangesList" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="0,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Parametro" Width="220" DisplayMemberBinding="{Binding Key}" />
                            <GridViewColumn Header="Da" Width="80" DisplayMemberBinding="{Binding OldValue}" />
                            <GridViewColumn Header="A" Width="80" DisplayMemberBinding="{Binding NewValue}" />
                            <GridViewColumn Header="Motivo" Width="330" DisplayMemberBinding="{Binding Reason}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
            <Button x:Name="RestoreBackupButton" Content="Ripristina backup" Style="{StaticResource PrimaryButton}" Background="#2A3560" Click="RestoreBackupButton_Click" Margin="0,0,10,0" />
            <Button x:Name="AnalyzeButton" Content="Rileva ed Analizza" Style="{StaticResource PrimaryButton}" Click="AnalyzeButton_Click" Margin="0,0,10,0" />
            <Button x:Name="ApplyButton" Content="Applica ottimizzazione" Style="{StaticResource PrimaryButton}" Click="ApplyButton_Click" IsEnabled="False" />
        </StackPanel>

        <!-- Status bar -->
        <Border Grid.Row="7" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="12,8">
            <TextBlock x:Name="StatusText" Text="Pronto." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
